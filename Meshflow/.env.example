# Server
DEBUG=true
ALLOWED_HOSTS="meshcontrol, meshcontrol.local"
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"
SERVE_STATIC_FILES=true

# Database (pre-prod)
POSTGRES_DB=meshflow_preprod
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Monitoring
PROMETHEUS_PASSWORD=prometheus

# Redis — same REDIS_* host/password for: DB 0 (Django Channels), DB 1 (Celery broker),
# DB 2 (django.core.cache / traceroute rotation + constellation envelope TTL)
REDIS_HOST=docker-1
REDIS_PORT=6380
REDIS_PASSWORD=SuperSecretPassword4

# Auto-traceroute source picker: least_recently_used | random | stratified_lru
# AUTO_TR_SOURCE_SELECTION_ALGO=least_recently_used

# Celery broker (optional; defaults to redis://:REDIS_PASSWORD@REDIS_HOST:REDIS_PORT/1)
# For Docker: CELERY_BROKER_URL=redis://redis:6379/1
# CELERY_BROKER_URL=

# Social auth
CALLBACK_URL_BASE=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Set this if you want to use Social Auth models to store OAuth provider credentials
# Set to 0 if you want to use env vars
AUTH_SITE_ID=1

# Google auth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Github auth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j
